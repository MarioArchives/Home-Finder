.git
.venv
.claude
.env
__pycache__
*.pyc

# Node build deps (rebuilt in Docker)
ui/node_modules
ui/dist

# Scraped data (generated at runtime)
data/*_listings.json
data/*_amenities.json

# Personal data (Docker uses seed files — only seed files are copied)
data/alerts.json
data/chat_ids.json
data/seen_listings.json
data/config.json
data/cron.log
data/.env.*

# Exclude all JSON except what Docker needs
ui/public/listings.json
ui/public/amenities.json
