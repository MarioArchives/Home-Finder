# =============================================================================
# Property Scraper — Docker environment
# =============================================================================
# This file is used by docker-compose. Telegram credentials are configured
# through the UI after first launch (Alerts tab).

# ── Scraper defaults (overridden by the setup wizard) ──────────────────────
CITY=Manchester
LISTING_TYPE=rent
PAGES=5
SOURCE=rightmove

# ── Telegram — leave empty, configured via the UI ──────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
